# Qdrant Cloud
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# Embedding model (default works out of box)
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
EMBEDDING_DIM=1024

# Collection names
KNOWLEDGE_COLLECTION=health_knowledge_base
MEMORY_COLLECTION=user_memory

# Vapi
VAPI_API_KEY=your_vapi_api_key
VAPI_SECRET=your_vapi_webhook_secret

# Server
HOST=0.0.0.0
PORT=8000
SERVER_URL=https://your-deployed-url.onrender.com
